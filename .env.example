# Kopyala: cp .env.example .env (Windows: copy .env.example .env)

# API
NODE_ENV=development
PORT=3000
API_PUBLISH_PORT=3000
API_PREFIX=/api
TRUST_PROXY=false
# Expo / web geliştirme: * veya http://localhost:8081,http://localhost:19006
CORS_ORIGINS=*

JWT_SECRET=güçlü-uzun-rastgele-bir-metin-productionda-değiştir
JWT_EXPIRES_IN=7d

# Yerel API + Prisma (bilgisayarda PostgreSQL, örn. docker infra port 5432): localhost kullan
DATABASE_URL=postgresql://prepup:prepup@localhost:5432/prepup
#
# docker compose ... -f docker-compose.infra.yml --profile infra: api servisi DATABASE_URL’i
# otomatik olarak postgres hostname ile alır (.env’de localhost kalabilir)
# REDIS_URL=redis://redis:6379
#
# Yerel şema: cd backend && npm run db:migrate

POSTGRES_USER=prepup
POSTGRES_PASSWORD=prepup
POSTGRES_DB=prepup
POSTGRES_PUBLISH_PORT=5432
REDIS_PUBLISH_PORT=6379

# Expo/React Native (.env kökünde): telefonda bilgisayar IP’sini kullanın
# EXPO_PUBLIC_API_URL=http://192.168.1.105:3000
# Android emülatör: http://10.0.2.2:3000
